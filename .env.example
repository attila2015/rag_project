# ── Model server ──────────────────────────────────────────────
MODEL_SERVER_URL=http://localhost:8080/v1
MODEL_NAME=qwen2.5-vl-7b-q4_k_m      # must match filename in models/

# Dummy API key (llama.cpp server accepts any non-empty value)
OPENAI_API_KEY=local-llama-key

# ── Model weights ─────────────────────────────────────────────
# Absolute path to the .gguf file (auto-resolved if left empty)
MODEL_PATH=

# ── Server tuning ─────────────────────────────────────────────
N_GPU_LAYERS=35        # -1 = all layers on GPU; 0 = CPU only
N_CTX=8192             # context window (tokens)
N_THREADS=8            # CPU threads (ignored if GPU)
TEMPERATURE=0.1        # low = more deterministic JSON output
MAX_TOKENS=2048

# ── MLflow tracking ───────────────────────────────────────────
MLFLOW_TRACKING_URI=./logs/mlruns
MLFLOW_EXPERIMENT_NAME=poc_qwen_document_intelligence

# ── Pipeline behaviour ────────────────────────────────────────
LOG_LEVEL=INFO
SAVE_INTERMEDIATE=true    # keep processed images in data/processed/
